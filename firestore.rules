// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: clients
// Fields: name (string), cpf (string), address (string), contact (string), createdAt (timestamp)
//
// Collection: projects
// Fields: clientId (string), name (string), description (string), totalValue (number), status (string), createdAt (timestamp)
//
// Collection: projects/{projectId}/installments
// Fields: projectId (string), amount (number), percentage (number), dueDate (timestamp), status (string), paidAt (timestamp)
//
// Collection: expenses
// Fields: projectId (string, optional), description (string), amount (number), date (timestamp), category (string)
//
// Collection: settings
// Fields: reminderDays (number), reminderMessageTemplate (string)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dolpholopes@gmail.com" && request.auth.token.email_verified == true));
    }

    // Generic validation helpers
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.cpf is string && data.cpf.size() >= 11;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 &&
             data.totalValue is number && data.totalValue >= 0 &&
             data.status in ['active', 'completed', 'cancelled'];
    }

    function isValidInstallment(data) {
      return data.amount is number && data.amount >= 0 &&
             data.percentage is number && data.percentage >= 0 && data.percentage <= 100 &&
             data.status in ['pending', 'paid'];
    }

    function isValidExpense(data) {
      return data.description is string && data.description.size() > 0 &&
             data.amount is number && data.amount >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /clients/{clientId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /projects/{projectId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /installments/{installmentId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /expenses/{expenseId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
